; MULTIX System Assembly v0.0.10
; Точка входу ОС (Bootloader)

RAM_START  0x80000000
STACK_SIZE 0x2000

# 0 
    ; Читаємо апаратний номер ядра
    x1 [mhartid]
    
    ? x1 > 0
        %                           ; Безкінечний цикл для сплячих ядер
            _                       
            
    ; Налаштовуємо тіньовий стек
    s0 RAM_START + STACK_SIZE
    
    ; Виклики через camelCase (пласка ієрархія, прямі шляхи)
    system.hardware.init -s0
    system.memory.init -s0
    system.process.init -s0
    
    system.hardware.wakeUpAllCores -s0

    system.process.run -s0
    
    system.panic "main loop exited"
