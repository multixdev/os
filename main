; MULTIX System Assembly v0.0.16
; Точка входу ОС
:
    ; Читаємо апаратний номер ядра з регістра CSR
    x1 csr.mhartid

    ; Якщо я НЕ Ядро 0 - йду спати
    ? x1 > 0 . sleep_core
            
    ; Вираховуємо адресу стеку (без квадратних дужок - це просто числа!)
    s0 config.ram_start + config.stack_size

    ; Запуск модулів. Компілятор сам розкриє цілі (наприклад, init.milkv_jupiter)
    system.hardware.init
    system.memory.init
    system.process.init
    
    system.hardware.wake_up_all_cores
    system.process.run

    system.panic "main loop exited"

: sleep_core
    !                         ; HALT (Wait For Interrupt)
    . sleep_core
