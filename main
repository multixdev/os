; MULTIX System Assembly v0.0.17
; Точка входу ОС
:
    ; Читаємо апаратний номер ядра з регістра CSR
    = x1 csr.m_hart_id

    ; Якщо я НЕ Ядро 0 - йду спати
    ? x1 > 0 . sleep_core
            
    ; Ініціалізація тіньового стеку системою (тільки в ядрі/завантажувачі)
    = msa.stack_address config.SHADOW_STACK_START
    = msa.stack_size    config.SHADOW_STACK_SIZE

    ; Запуск модулів. Компілятор сам розкриє цілі (наприклад, init.milkv_jupiter)
    @ system.hardware.init
    @ system.memory.init
    @ system.process.init
    
    @ system.hardware.wake_up_all_cores
    @ system.process.run

    ;@ system.panic "main loop exited"

: sleep_core
    !                       ; HALT (Wait For Interrupt)
    . sleep_core
