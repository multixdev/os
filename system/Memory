; MULTIX System Assembly v0.0.4
; System/Memory - Лінійний Менеджер Фізичної Пам'яті

RAM_MAX 0x88000000       ; Кінець доступної RAM (напр. 128 MB)

; Глобальна змінна (вказівник на наступний вільний байт)
; Буде знаходитись за фіксованою адресою (наприклад, 0x80000100)
FREE_PTR 0x80000100

Init
    ; Задаємо початкову вільну адресу (після коду Ядра, напр. 1MB)
    x5 0x80100000        
    [FREE_PTR] x5        ; Зберігаємо в змінну
    s0+                  ; Повернення

; Alloc (Виділення безперервного шматка)
; Вхід: x10 (розмір у байтах)
; Вихід: x10 (адреса початку) або 0 (якщо пам'ять закінчилась)
Alloc
    x5 [FREE_PTR]        ; Читаємо поточний вказівник
    x6 x5 + x10          ; Рахуємо нову межу

    x7 RAM_MAX
    ? x6 >= x7
        x10 0            ; Out of Memory
        s0+
        
    [FREE_PTR] x6        ; Оновлюємо глобальний вказівник
    x10 x5               ; Повертаємо виділену адресу
    s0+
