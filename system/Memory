; Менеджер Фізичної Пам'яті

RAM_END 0x88000000         ; Наприклад, маємо 128 MB RAM

; Локальна змінна для відстеження вільних адрес
; Знаходиться на початку вільної зони
Init
    x5 0x80010000          ; Початкова адреса вільної пам'яті (після коду Ядра)
    x6 0x80000000          ; Адреса, де ми зберігаємо вказівник
    @ x6 x5                ; Зберігаємо початковий вказівник
    s0+

; Функція Alloc
; Приймає: x10 - розмір у байтах
; Повертає: x10 - адреса виділеної пам'яті (або 0, якщо помилка)
Alloc
    x5 0x80000000          ; Адреса нашої змінної вказівника
    x6 @ x5                ; Читаємо поточний вільний вказівник

    x7 x6 + x10            ; Рахуємо нову адресу (поточна + запитаний розмір)
    x8 RAM_END
    
    ? x7 >= x8             ; Перевіряємо чи не вийшли за межі RAM
        x10 0              ; Помилка (Out of Memory)
        s0+
        
    @ x5 x7                ; Записуємо новий вказівник у пам'ять
    x10 x6                 ; Повертаємо стару адресу (початок виділеного блоку)
    s0+
